{
  "name": "testweave",
  "publisher": "paulyestchick",
  "displayName": "TestWeave",
  "description": "%app.description%",
  "version": "0.1.10",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "repository": {
    "url": "https://github.com/paulyeshchyk/testweave"
  },
  "changelogUrl": "https://github.com/paulyeshchyk/testweave/blob/main/CHANGELOG.md",
  "releaseNotes": "https://github.com/paulyeshchyk/testweave/blob/main/CHANGELOG.md",
  "main": "dist/extension.js",
  "files": [
    "dist",
    "src/generate-tests.js",
    "package.nls.json",
    "package.nls.ru.json",
    "README.md",
    "README.ru.md",
    "CHANGELOG.md",
    "LICENSE.md"
  ],
  "contributes": {
    "commands": [
      {
        "command": "jsgeneratetests.generateTests.run",
        "title": "%jsgeneratetests.generateTests.run.title%"
      },
      {
        "command": "jsgeneratetests.generateTests.settings",
        "title": "%jsgeneratetests.generateTests.settings.title%"
      }
    ],
    "submenus": [
      {
        "id": "jsgenerateTests.submenu",
        "label": "%jsgenerateTests.submenu.title%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "jsgenerateTests.submenu",
          "when": "explorerResourceIsFolder",
          "group": "navigation@1"
        }
      ],
      "jsgenerateTests.submenu": [
        {
          "command": "jsgeneratetests.generateTests.run",
          "when": "explorerResourceIsFolder",
          "group": "1_top@1"
        },
        {
          "command": "jsgeneratetests.generateTests.settings",
          "when": "explorerResourceIsFolder",
          "group": "1_top@2"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "generateTests.defaultRootDir": {
          "type": "string",
          "default": "",
          "description": "%configuration.generateTests.defaultRootDir%"
        },
        "generateTests.defaultOutputDir": {
          "type": "string",
          "default": "",
          "description": "%configuration.generateTests.defaultOutputDir%"
        },
        "generateTests.overwrite": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.generateTests.overwrite%"
        },
        "generateTests.skipIndexJs": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.generateTests.skipIndexJs%"
        },
        "generateTests.iife": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.generateTests.iife%"
        }
      }
    }
  },
  "bin": {
    "testweave": "src/generate-tests.js"
  },
  "scripts": {
    "compile": "node build.js",
    "type-check": "tsc --noEmit",
    "build": "npm run compile",
    "build:prod": "cross-env NODE_ENV=production npm run compile",
    "build:dev": "cross-env NODE_ENV=development npm run compile",
    "watch": "node build.js --watch",
    "vscode:prepublish": "npm run build:prod",
    "package": "npm run build:prod && vsce package -o ./build",
    "publish-vsix": "vsce publish",
    "publish": "npm run package && npm run publish-vsix",
    "format": "prettier --write .",
    "release:patch": "npm run build:prod && node scripts/bump-version.js",
    "release:minor": "npm run build:prod && node scripts/bump-minor.js",
    "test": "jest"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "jest": "^30.4.2"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "globals": "^17.7.0"
  }
}